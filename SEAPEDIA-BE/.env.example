# Port server (Nginx bakal proxy ke port ini)
PORT=5000

# WAJIB "production" di VPS — ini yang ngaktifin cookie secure + sameSite=none
NODE_ENV=production

# Koneksi PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/seapedia?schema=public"

# Secret JWT — generate random panjang, mis: openssl rand -hex 32
JWT_SECRET="ganti_dengan_random_string_panjang"

# URL frontend (buat CORS). HARUS sama persis dengan domain FE, tanpa trailing slash
FRONTEND_URL="https://app.domain-lu.com"
