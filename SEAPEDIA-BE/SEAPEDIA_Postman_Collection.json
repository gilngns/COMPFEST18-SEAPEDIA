{
  "info": {
    "name": "SEAPEDIA API",
    "description": "API Documentation for SEAPEDIA Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:5000/api/auth/register", "host": ["http://localhost:5000"], "path": ["api", "auth", "register"] },
            "body": { "mode": "raw", "raw": "{\"username\":\"johndoe\", \"email\":\"john@example.com\", \"password\":\"password123\"}" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "http://localhost:5000/api/auth/login", "host": ["http://localhost:5000"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\"email\":\"john@example.com\", \"password\":\"password123\"}" }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:5000/api/auth/me", "host": ["http://localhost:5000"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "Get Products",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:5000/api/catalog?page=1&limit=10", "host": ["http://localhost:5000"], "path": ["api", "catalog"] }
          }
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:5000/api/catalog/product-id", "host": ["http://localhost:5000"], "path": ["api", "catalog", "product-id"] }
          }
        }
      ]
    }
  ]
}
